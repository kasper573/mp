{
  "name": "@mp/loadtest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsgo",
    "start:dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f ../../docker/.env.dev ../../docker/.env.shared -- vite-node src/index.ts --inspect-brk",
    "start:test": "NODE_TLS_REJECT_UNAUTHORIZED=0 dotenvx run -f ../../docker/.env.test ../../docker/.env.shared -- vite-node src/index.ts"
  },
  "dependencies": {
    "@mp/auth": "workspace:*",
    "@mp/logger": "workspace:*",
    "@mp/math": "workspace:*",
    "@mp/std": "workspace:*",
    "@mp/time": "workspace:*",
    "@mp/world": "workspace:*",
    "@preact/signals-core": "catalog:"
  },
  "devDependencies": {
    "@mp/tsconfig": "workspace:*",
    "@types/yargs": "catalog:",
    "tsx": "catalog:",
    "vite": "catalog:",
    "yargs": "catalog:"
  }
}
