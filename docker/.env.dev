# These are the default container environment variables for development.
# Do not put secrets here.
MP_DOMAIN=mp.localhost
METRICS_SCRAPE_INTERVAL_MS=2000
METRICS_SCRAPE_TIMEOUT_MS=1000
MP_BUILD_VERSION=dev
MP_GAME_SERVICE_AUTH__ALLOW_BYPASS_USERS=true
MP_GAME_SERVICE_LOG__LEVEL=debug
MP_GAME_SERVICE_LOG__PRETTY=true
MP_GAME_SERVICE_RNG_SEED=1
MP_GAME_SERVICE_TILED_BASE_URL=https://files.${MP_DOMAIN}/
MP_GAME_SERVICE_PROXY_HOST=host.docker.internal:8090
PUSHGATEWAY_PROXY_HOST=localhost:9091
MP_WEBSITE_PROXY_HOST=host.docker.internal:5173
MP_WEBSITE_EMBED_ENV=true
MP_WEBSITE_DISPLAY_ERROR_DETAILS=true
KC_PUBLIC_BASE_URL=http://localhost:8080
KC_VERIFY_EMAIL=false
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin
CADDY_RATE_LIMIT_EVENTS=999999 # essentially unlimited
