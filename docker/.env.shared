# OpenTelemetry standard
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://tempo:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
OTEL_LOG_LEVEL="error"

# Postgres
POSTGRES_USER=mp
POSTGRES_PASSWORD=mp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SERVER_ROOT_URL=https://grafana.${MP_DOMAIN}
PROMETHEUS_SCRAPE_INTERVAL=${METRICS_SCRAPE_INTERVAL_MS}ms
PROMETHEUS_SCRAPE_TIMEOUT=${METRICS_SCRAPE_TIMEOUT_MS}ms
FARO_RECEIVER_CORS_ALLOWED_ORIGIN=https://${MP_DOMAIN}

# drizzle-kit seems to have issues with introspecting non drizzle databases,
# so we keep game related data in its own database and infra related data in another.
POSTGRES_GAME_DB=mp_game
POSTGRES_INFRA_DB=mp_infra
POSTGRES_MULTIPLE_DATABASES=${POSTGRES_GAME_DB},${POSTGRES_INFRA_DB}

# Postfix
ALLOWED_SENDER_DOMAINS=${MP_DOMAIN}
HOSTNAME=mail.${MP_DOMAIN}

# Postgres exporter
DATA_SOURCE_USER=${POSTGRES_USER}
DATA_SOURCE_PASS=${POSTGRES_PASSWORD}

# Keycloak
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_INFRA_DB}?user=${POSTGRES_USER}&password=${POSTGRES_PASSWORD}
KC_DB_USERNAME=${POSTGRES_USER}
KC_DB_PASSWORD=${POSTGRES_PASSWORD}
KC_HOSTNAME=https://auth.${MP_DOMAIN}
KC_HTTP_ENABLED=true
KC_PROXY_HEADERS=xforwarded
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KC_SMTP_FROM=no-reply@${MP_DOMAIN}
KC_SMTP_FROM_DISPLAY_NAME=MP
KC_SMTP_HOST=postfix
KC_SMTP_PORT=587
KC_SMTP_AUTH=false # Postfix doesn't require auth

# File server
MP_FILE_SERVER_DOMAIN=files.${MP_DOMAIN}

# Service domains
MP_WEBSITE_DOMAIN=${MP_DOMAIN}
MP_GAME_SERVER_DOMAIN=game.${MP_DOMAIN}

# Game server
MP_GAME_SERVER_PORT=8090
MP_GAME_SERVER_METRICS_PORT=8091
MP_GAME_SERVER_AUTH__ISSUER=${KC_HOSTNAME}/realms/mp
MP_GAME_SERVER_AUTH__AUDIENCE=mp

# Client
MP_WEBSITE_VERSION=${MP_BUILD_VERSION}
MP_WEBSITE_GAME_SERVER_URL=wss://${MP_GAME_SERVER_DOMAIN}
MP_WEBSITE_FILE_SERVER_URL=https://${MP_FILE_SERVER_DOMAIN}
MP_WEBSITE_AUTH__REDIRECT_URI=https://${MP_WEBSITE_DOMAIN}/auth-callback
MP_WEBSITE_AUTH__AUTHORITY=${KC_HOSTNAME}/realms/mp
MP_WEBSITE_AUTH__AUDIENCE=mp
MP_WEBSITE_FARO__RECEIVER_URL=https://faro.${MP_DOMAIN}/collect
MP_WEBSITE_FARO__PROPAGATE_TRACE_HEADER_CORS_URLS=${MP_WEBSITE_FARO__RECEIVER_URL},wss://${MP_GAME_SERVER_DOMAIN}
