{
  "name": "@mp/world",
  "version": "0.0.0",
  "sideEffects": false,
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "bench": "pnpm bench:perf && pnpm bench:packets && pnpm bench:bounds",
    "bench:packets": "tsx scripts/packet-bench.ts",
    "bench:perf": "node --expose-gc --import tsx scripts/perf-bench.ts",
    "bench:bounds": "tsx scripts/bounds-bench.ts",
    "bench:profile": "node --cpu-prof --cpu-prof-dir=profiles --heap-prof --heap-prof-dir=profiles --import tsx scripts/profile-bench.ts"
  },
  "dependencies": {
    "@mp/auth": "workspace:*",
    "@mp/engine": "workspace:*",
    "@mp/fixtures": "workspace:*",
    "@mp/graphics": "workspace:*",
    "@mp/keycloak": "workspace:*",
    "@mp/math": "workspace:*",
    "@mp/path-finding": "workspace:*",
    "@mp/state": "workspace:*",
    "@mp/std": "workspace:*",
    "@mp/style": "workspace:*",
    "@mp/tiled-loader": "workspace:*",
    "@mp/tiled-renderer": "workspace:*",
    "@mp/time": "workspace:*",
    "@mp/ui": "workspace:*",
    "@mp/validate": "workspace:*",
    "@preact/signals-core": "catalog:",
    "@rift/core": "workspace:*",
    "@rift/reactive": "workspace:*",
    "@rift/types": "workspace:*",
    "@rift/ws": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "partysocket": "^1.1.18",
    "preact": "catalog:",
    "uniqolor": "1.1.1",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@mp/tsconfig": "workspace:*",
    "@types/yargs": "catalog:",
    "mitata": "catalog:",
    "tsx": "catalog:",
    "yargs": "catalog:"
  }
}
